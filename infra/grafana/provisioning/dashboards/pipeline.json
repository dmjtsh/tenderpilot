{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Pipeline health, tender counts, coverage",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Данные",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "active" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "finished" }, "properties": [ { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "tenderpilot_tenders_total{source=\"eis\", status=\"active\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "tenderpilot_tenders_total{source=\"eis\", status=\"finished\"}",
          "legendFormat": "finished",
          "refId": "B"
        }
      ],
      "title": "ЕИС (44-ФЗ / 223-ФЗ)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "active" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "finished" }, "properties": [ { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "tenderpilot_tenders_total{source=\"tenderguru\", status=\"active\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "tenderpilot_tenders_total{source=\"tenderguru\", status=\"finished\"}",
          "legendFormat": "finished",
          "refId": "B"
        }
      ],
      "title": "TenderGuru (b2b)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "tenderpilot_unenriched_tenders_total",
          "legendFormat": "Не обогащены",
          "refId": "A"
        }
      ],
      "title": "Не обогащены",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "tenderpilot_unembedded_tenders_total",
          "legendFormat": "Без вектора",
          "refId": "A"
        }
      ],
      "title": "Без вектора (Qdrant)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 50 }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "tenderpilot_documents_total",
          "legendFormat": "{{parse_status}}",
          "refId": "A"
        }
      ],
      "title": "Документы по статусу",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "increase(tenderpilot_tenders_total{status=\"active\",source=\"eis\"}[1h])",
          "legendFormat": "EIS новые/час",
          "refId": "A"
        },
        {
          "expr": "increase(tenderpilot_tenders_total{status=\"active\",source=\"tenderguru\"}[2h])",
          "legendFormat": "TenderGuru новые/2ч",
          "refId": "B"
        }
      ],
      "title": "Новые тендеры (скорость наполнения)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Pipeline Tasks",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "dateTimeFromNow",
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "tenderpilot_pipeline_last_success_timestamp_seconds{task_name=\"sync_active_tenders\"} * 1000",
          "legendFormat": "sync_active_tenders",
          "refId": "A"
        },
        {
          "expr": "tenderpilot_pipeline_last_success_timestamp_seconds{task_name=\"sync_tenderguru\"} * 1000",
          "legendFormat": "sync_tenderguru",
          "refId": "B"
        },
        {
          "expr": "tenderpilot_pipeline_last_success_timestamp_seconds{task_name=\"enrich_tender\"} * 1000",
          "legendFormat": "enrich_tender",
          "refId": "C"
        },
        {
          "expr": "tenderpilot_pipeline_last_success_timestamp_seconds{task_name=\"embed_tender\"} * 1000",
          "legendFormat": "embed_tender",
          "refId": "D"
        },
        {
          "expr": "tenderpilot_pipeline_last_success_timestamp_seconds{task_name=\"cleanup_doc_chunks\"} * 1000",
          "legendFormat": "cleanup_doc_chunks",
          "refId": "E"
        }
      ],
      "title": "Последний успешный запуск задач",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "tenderpilot_pipeline_last_duration_ms",
          "legendFormat": "{{task_name}}",
          "refId": "A"
        }
      ],
      "title": "Длительность последнего запуска (мс)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 26 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "tenderpilot_pipeline_errors_last_run",
          "legendFormat": "{{task_name}}",
          "refId": "A"
        }
      ],
      "title": "Ошибки в последнем запуске",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["tenderpilot", "pipeline"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Moscow",
  "title": "Tenderpilot — Pipeline & Data",
  "uid": "tenderpilot-pipeline",
  "version": 1
}
